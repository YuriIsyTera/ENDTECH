RegistryHyperNet.addResearchCognitionData(ResearchCognitionData.create("Mega-WindTurbineTech", "大规模平流层风力发电技术",<modularmachinery:mega_windturbine_controller>,    // 预览物品
        10.1,                                 // 科技等级（难度）
        250000000,                          // 需要科研点
        5000.0F,                               // 最低每 Tick 算力要求
        [
            "风力发电——曾被用于我们文明的起步阶段的清洁能源之一，其因效率过低被时代遗弃。",
            "但自从我们的科技水平达到了可以用极小的能量促进一场飓风，风力发电似乎又走上了历史的舞台。",
            "",
            "§7研究此项目将启动一个§2全新§7的技术分支",
        ],
        [
            "通过紫晶素一定的修复作用，我们可以建造一座从地面到平流层的风力发电机——巨型平流层风力发电机，",
            "§2解锁集成式处理车间配方:巨型平流层风力发电机控制器",
            "§2解锁集成式处理车间配方:巨型平流层风力发电机集成控制器",
            "最大线程数:32",
            "",
            "§2§o文案：RTG3521,模型：RTG3521,代码：RTG3521",
        ],
        [
            "eco_y7",
            "site",
        ]
));
RegistryHyperNet.addResearchCognitionData(ResearchCognitionData.create("Mega-StartingTech", "黎明的曙光",<contenttweaker:dust>,    // 预览物品
        14.1,                                 // 科技等级（难度）
        2500000000,                          // 需要科研点
        6000000.0F,                               // 最低每 Tick 算力要求
        [
            "通过对各项不同系科技的研究，生产类似方舟锭的材料已经不成问题，我们也拥有了在外太空制造机械的能力，但这些远远不够。",
            "——我们大部分机器的产能仍然低下，我们需要改革。",
        ],
        [
            "为应对这些疯狂的原材料与加工需求，ECO实验室内部策划了多种方案。",
            "——最终,一项创世纪的计划——§3巨构计划§f被提名。",
            "",
            "解锁新科技体系:§3巨构计划§f",
            "此计划将使用近地轨道通讯中枢体系并以大量昂贵材料来制造高效率机械。",
            "",
            "§2§o文案：RTG3521",
        ],
        [
            "Mega-WindTurbineTech",
            "atomicprocess",
            "theory_emeber",
            "theory_void_energy",
            "theory_computer_milkway",
        ]
));
RegistryHyperNet.addResearchCognitionData(ResearchCognitionData.create("Mega-AdvancedBaseMachineTech", "§3巨构计划§f:基础加工强化",<contenttweaker:terminal_blueprint>,    // 预览物品
        15,                                 // 科技等级（难度）
        250000000000,                          // 需要科研点
        6000000.0F,                               // 最低每 Tick 算力要求
        [
            "长久以来，我们的基础加工只能使用简单与无趣的机械。",
            "Nova看着那些旧时代的象征——沉默转动的车床、往复运动的冲压机、恒温熔炼的铸造炉。",
            "我们需要改革。",
            "基础加工是一切的基础，如果没有一台好的机械，即使我们拥有再多资源，那它们也是垃圾。",
            "",
            "研究此项目以推进§3巨构计划§f至下一阶段",
        ],
        [
            "§3巨构计划§f启动后，改革基础加工被第一个提名。",
            "以我们的技术，我们已经可以制造出§6次时代§f的机械。",
            "利用余烬金属和虚空能，我们可以制造效率极高且体积较小的机械",
            "又因其原理仅仅是加大能源输入与改进材料，所以这个机械的系列被我们称为——家用系列。",
            "",
            "§2解锁原子制程构造合成阵列配方:§f“家用”锻造锤集成控制器",
            "§2解锁原子制程构造合成阵列配方:§f“家用”破壁机集成控制器",
            "§2解锁原子制程构造合成阵列配方:§f“家用”注液器集成控制器",
            "§2解锁原子制程构造合成阵列配方:§f“家用”工作台集成控制器",
            "",
            "§2§o文案：RTG3521,模型：RTG3521,GTNH搬运,代码：RTG3521",
        ],
        [
            "Mega-StartingTech",
        ]
));
RegistryHyperNet.addResearchCognitionData(ResearchCognitionData.create("Mega-SpaceElevator-Stage1", "§3巨构计划§f:§b太空电梯§f-材料",<contenttweaker:nova_ingot>,    // 预览物品
