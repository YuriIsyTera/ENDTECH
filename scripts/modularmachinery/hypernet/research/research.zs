#priority 700
#loader crafttweaker reloadable

import novaeng.hypernet.RegistryHyperNet;
import novaeng.hypernet.research.ResearchCognitionData;
import crafttweaker.util.Math;
RegistryHyperNet.addResearchCognitionData(ResearchCognitionData.create("site", "§1架起天空之桥",
    <contenttweaker:mk1satellite>,
    9.0,
    24000.0*1000.0f*2,
    1000.0f,
    [
    "仅仅发射卫星探测已经满足不了我们的要求，我们需要向太空中发射更复杂，具有更大质量的巨型机械",
    "为了完成这一壮举,我们的工厂也不应仅仅局限在地球之上",
    "建造深空工厂绝非易事,我们遇到的第一个难题便是如何向深空中发射大量航天器来构造我们的轨道工厂",
    "利用传统火箭进行发射的效率较为低下,我们迫切需要一种可重复利用的高效发射手段",
    "将发射轨道建的足够高，直通地球和太空？现阶段我们找不到这样一种坚固材料来承受恐怖的应力。",
    "§b但是这种想法并非不切实际",
    ],
    [
    "解锁集成式处理车间配方:§7洛夫斯特罗姆基§6基座§f,采集无人机§6Mk1,射电望远镜阵列组件§cMk1,运载火箭§aMk1,遥感卫星§bMk1",
    "解锁集成式处理车间配方:§9航天工业集成制造车间",
    "利用流体的惯性，我们可以将结构本应承受的重力“移除”",
    "我们的系统就像一个巨大的喷泉，绝大部分质量都来自于流体，喷泉只要足够的快，物体就能被喷泉带的足够的高",
    "而后流体处于自由落体状态，自然而然的回到地面，不用使我们的系统进行额外的承重",
    "而我们所要做的，就是制造一个这样巨大的喷泉，以及在喷泉上套上一层壳",
    "这允许我们以极低的成本向太空中大量发射航天器",
    "一个新的时代即将来临",
    ],
    [
        "mach_crafter",
        "dyson_sphere"
    ]
));

RegistryHyperNet.addResearchCognitionData(ResearchCognitionData.create("atomicprocess", "§6原子精度",
    <contenttweaker:arkchip>,
    9.6,
    24000.0*1000.0f*2,
    1000.0f,
    [
    "现有的装配机器已经完全无法满足我们大量高精度元件的需求，我们迫切需要对制造机器进行革新"
    ],
    [
    "解锁集成式处理车间配方:§6原子制程构造阵列",
    "通过大量的隧穿显微镜，辅之以成熟的力场操纵技术，我们得以看到甚至操纵原材料上的每一粒原子",
    "可以预见的是，我们的科技已经迎来了它的下一世代",
    "一场关于精度的革命"
    ],
    [
        "mach_crafter",
        "assembly_line"
    ]
));

RegistryHyperNet.addResearchCognitionData(ResearchCognitionData.create("planet_observe","§a聆听宇宙之音",
  <contenttweaker:unknownplanet>,
  9.0,
  24000.0*1000.0f*2,
  1000.0f,
  [
    "在无垠的黑暗幕布上，星辰并非沉默的钻石，而是以光年为单位吟唱的诗人。我们曾以为宇宙是寂静的，直到学会聆听它真正的语言——那是射电波的绵长低语，是穿越时空的电磁韵律",
    "科技在进步，文明对资源的需求也在日益增长。因此，人类的视野必然投向地外空间。天体，作为宇宙最基本的物质集合与能量载体，其资源潜力已成为当前和未来空间科技发展的核心议题之一",
    "对它们的认知，已从纯粹的科学研究对象，扩展到具有明确实用价值的勘探目标"
  ],
  [
    "解锁集成式处理车间配方:§e天体观测分析中心",
    "传统的光学与射电观测，主要服务于天体物理研究，揭示其形成、演化与物理状态。然而，当我们以“资源”的视角重新审视这些数据时，其意义发生了深刻转变",
    "天体观测分析中心的功能，也相应地从广义探索，向“评估宇宙矿藏”的精准分析拓展",
    "作为这一演进的核心基础设施，天体观测分析中心的功能已超越传统天文学范畴，成为一个综合性的“地外资源信息中心”",
    "§6由此,叩响新世界的大门"
  ],
  [
    "mach_crafter",
    "theory_of_dyson_cloud",
    "site",
  ]
));

RegistryHyperNet.addResearchCognitionData(ResearchCognitionData.create("coolingcasade","§9人工冷库",
  <contenttweaker:assemblycore>,
  9.6,
  24000.0*1000.0f*2,
  1000.0f,
  [
    "在尖端科学工程与前沿技术领域，极低温环境已成为不可或缺的基础条件",
    "其中，液氦温区（4.2 K，-268.95 ℃）及以下的超流氦（低于2.17 K）因其独特的超流动性与极高的热传导能力，成为支撑超导技术、大科学装置及量子研究的核心低温介质",
    "然而，获得并维持大规模、稳定可靠的超流氦环境，是一项极具挑战性的复杂系统工程"
  ],
  [
    "解锁集成式处理车间配方:§9工业级联冷却架构",
    "工业级联冷却架构的本质是将不同热力学循环的制冷机按温区串联，逐级将热量从低温端泵送至高温端，最终由室温冷却介质带走",
    "该架构摒弃了传统依赖大量液氦灌注与蒸发损耗的“开环”模式，转向高效、可持续的“闭环”制冷",
    "它将多个成熟的制冷循环通过系统化集成与精密控制，提升为一个可靠、高效、可大规模部署的极低温“工厂”",
    "大规模的超流氦制备启动，我们获取了一种高效的冷却液体，为我们即将制备的内置大型超导磁体的机器提供了理想的工作环境"
  ],
  [
    "mach_crafter",
    "tokmak_reactor",
  ]
));

RegistryHyperNet.addResearchCognitionData(ResearchCognitionData.create("theory_energy","§a高能加速理论",
  <contenttweaker:fwzrlb>,
  9.7,
  24000.0*1000.0f*2,
  1000.0f,
  [
    "高能粒子加速器是探索物质基本结构、宇宙起源及前沿应用的核心工具。传统基于射频腔的加速器在过去一个世纪主导了该领域，但其面临的技术瓶颈日益突出",
    "以超强超短激光脉冲驱动等离子体波的新一代加速方案，正带来一场根本性的技术范式变革，尤其在加速效率、系统规模及运行成本方面展现出颠覆性潜力",
    "传统射频加速器在由金属（如铜或超导铌）构成的谐振腔中激发微波频段，金属腔壁的电击穿阈值限制了可承受的电场强度",
    "需要辅之以庞大复杂的系统来确保其在当前科技背景下仍有一席之地",
    "但基于高能加速理论的激光等离子体加速器模型将超强飞秒激光脉冲聚焦射入气体靶或固体靶，通过有质动力在等离子体中激发出极端强烈的尾波场",
    "该尾波场的纵向电场强度可比传统射频腔高3-4个数量级",
    "我们将其称之为高效"
  ],
  [
    "解锁原子制程构造阵列配方:§9激光脉冲靶向§b轰击加速器",
    "该机器以一超强飞秒激光器和复数超大容量的能量立方取代了庞大的射频系统和隧道，在紧凑的加速介质中进行加速，无复杂真空腔体和精密磁铁阵列",
    "一台高度集成、能量高度集中、在微观尺度直接耦合光能与粒子动能的紧凑型“加速引擎”",
  ],
  [
    "mach_crafter",
    "beyond_limits",
  ]
));

