RegistryHyperNet.addResearchCognitionData(ResearchCognitionData.create("theory_destroyer_ii","§d噬星者§b-II",
  <contenttweaker:ultminingdevice>,
  13.0,
 24000.0*800000.0f*2,
    800000.0D,
