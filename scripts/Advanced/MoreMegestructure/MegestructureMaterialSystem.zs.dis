function regItem(name as string) {
    val item as Item = VanillaFactory.createItem(name);
    item.creativeTab = <creativetab:misc>;
    item.register();
}

function regItemWithStackSize(name as string, maxStackSize as int) {
    val item as Item = VanillaFactory.createItem(name);
    item.creativeTab = <creativetab:misc>;
    item.maxStackSize = maxStackSize;
    item.register();
}

function regFluid(regName as string, color as int, temperature as int) {
    var fluid = VanillaFactory.createFluid(regName, color);
    fluid.colorize = true;
    fluid.temperature = temperature;
    fluid.stillLocation = "base:fluids/liquid";
    fluid.flowingLocation = "base:fluids/liquid_flow";
    fluid.register();
}
function regEndTechMaterial(material as string,material_ingot as IIngredient) {
    val material_transmission as Item = VanillaFactory.createItem(material + "transmission");
    val material_connection as Item = VanillaFactory.createItem(material + "connection");
    val material_plate as Item = VanillaFactory.createItem(material + "plate");
    val material_rotor as Item = VanillaFactory.createItem(material + "rotor");
    val material_transmission_name = material + "transmission";
    val material_connection_name = material + "connection";
    val material_plate_name = material + "plate";
    val material_rotor_name = material + "rotor";
    val material_transmission_item as IIngredient = material + "transmission";
    val material_connection_item as IIngredient = material + "connection";
    val material_plate_item as IIngredient = material + "plate";
    val material_rotor_item as IIngredient = material + "rotor";
    val material_transmission_itemstack as IItemstack = "item:" + material + "transmission";
    val material_connection_itemstack as IItemstack = material + "connection";
    val material_plate_itemstack as IItemstack = material + "plate";
    val material_rotor_itemstack as IItemstack = material + "rotor";
    material_transmission.creativeTab = <creativetab:misc>;
    material_connection.creativeTab = <creativetab:misc>;
    material_plate.creativeTab = <creativetab:misc>;
    material_rotor.creativeTab = <creativetab:misc>;
    material_transmission.register();
    material_connection.register();
    material_plate.register();
    material_rotor.register();
    recipes.addShaped(material_connection_itemstack, [
        [material_ingot,null,null],
        [material_ingot,null,null],
        [null,null,null]
    ]);
    recipes.addShaped(material_rotor_itemstack, [
        [material_plate_item,null,material_plate_item],
        [null,material_connection_item,null],
        [material_plate_item,null,material_plate_item]
    ]);
    recipes.addShaped(material_transmission_itemstack, [
        [material_connection_item,material_connection_item,material_connection_item],
        [material_connection_item,null,material_connection_item],
        [material_connection_item,material_connection_item,material_connection_item]
    ]);
    Pressurizer.addRecipe(material_ingot, material_plate_item, 2.0D, 1.5D);
    Pressurizer.addRecipe(material_plate_item, material_connection_item * 2, 2.0D, 1.5D);
    RecipeBuilder.newBuilder("endtech" + material_rotor_name, "board_assembly_room", 10)
        .addEnergyPerTickInput(1000)
        .addInput(material_rotor_item)
        .addInput(material_connection_item)
        .addOutput(material_transmission_item)
        .build();
    RecipeBuilder.newBuilder("endtech" + material_rotor_name, "board_assembly_room", 10)
        .addEnergyPerTickInput(1000)
        .addInput(material_transmission_item)
        .addOutput(material_rotor_item)
        .build();
}
regEndTechMaterial("nova",<contenttweaker:nova_ingot>);